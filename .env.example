# ── Copy this file to .env and fill in your values ───────────────────────────
# cp .env.example .env

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Models — must be pulled in Ollama before running
EMBED_TEXT_MODEL=nomic-embed-text   # ollama pull nomic-embed-text
LLM_MODEL=gemma3:1b                 # ollama pull gemma3:1b
VLM_MODEL=llava-phi3               # ollama pull llava-phi3 (for scanned PDFs)

# CLIP — sentence-transformers model for shared image+text space
# Downloaded automatically on first run (~340MB from HuggingFace)
CLIP_MODEL=clip-ViT-B-32

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=            # leave blank for no auth (default docker-compose)
# Full URL (overrides host/port/password above if set)
REDIS_URL=redis://localhost:6379/0

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Chunking ──────────────────────────────────────────────────────────────────
SEMANTIC_THRESHOLD=0.3   # cosine distance to split chunks (0=same topic, 1=different)
MIN_CHUNK_WORDS=15

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_VECTOR=20
TOP_K_BM25=20
TOP_K_FINAL=5
RRF_K=60

# ── PDF rendering ─────────────────────────────────────────────────────────────
PDF_DPI=150              # 72=fast, 150=good quality, 300=slow+sharp
MIN_TEXT_CHARS=20        # below this → page treated as scanned
MIN_IMAGE_PX=80          # skip embedded images smaller than this

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/rag2.log   # leave blank to disable file logging
